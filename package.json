{
  "name": "drum-mic-planner",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:site": "VITE_BASE_PATH=/drum-recording-planner/ vite build --outDir dist-site",
    "validate:data": "node scripts/validate-data.mjs",
